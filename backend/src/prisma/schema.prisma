generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RideStatus {
  OPEN
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

model Ride {
  id                String     @id @default(uuid())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  driverId          String
  driver            User       @relation("DriverRides", fields: [driverId], references: [id])
  seatsAvailable    Int        @default(1)
  chargeCents       Int

  startTime         DateTime
  endTime           DateTime

  startPlaceName    String
  endPlaceName      String

  // PostGIS geometry (SRID 4326) stored as:
  // - startPoint/endPoint: POINT
  // - routeLine: LINESTRING
  startPoint        Unsupported("geometry(Point,4326)")?
  endPoint          Unsupported("geometry(Point,4326)")?
  routeLine         Unsupported("geometry(LineString,4326)")?

  status            RideStatus @default(OPEN)

  vehicleType       String     @default("CAR")
  vehicleCapacity   Int        @default(5)
  fuelType          String     @default("Petrol")
  vehicleNumber     String     @default("")

  requests          RideRequest[]

  @@index([startTime])
  @@index([endTime])
}

model RideRequest {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rideId         String
  ride           Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  riderId        String
  rider          User     @relation("RiderRequests", fields: [riderId], references: [id])
  riderStartName String
  riderEndName   String
  riderStartTime DateTime

  riderStart     Unsupported("geometry(Point,4326)")?
  riderEnd       Unsupported("geometry(Point,4326)")?

  status         RideStatus @default(REQUESTED)
  fareCents      Int        @default(1000)
  seats          Int        @default(1)

  @@index([rideId])
}

model User {
  id            String        @id @default(uuid())
  email         String?       @unique
  name          String
  firebaseUid   String        @unique
  phoneNumber   String?       @unique
  profilePic    String?
  passwordHash  String?
  role          String        @default("passenger")
  gender        String?
  fcmToken      String?
  society       String?
  workplace     String?
  bio           String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // A user can post many rides (as a driver)
  ridesAsDriver Ride[]        @relation("DriverRides")

  // A user can request many rides (as a rider)
  rideRequests  RideRequest[] @relation("RiderRequests")

  buddyRequests BuddyRequest[] @relation("RiderBuddyRequests")

  // Messages sent by this user
  messages      Message[]


  // Parking relations
  parkingSpots    ParkingSpot[]    @relation("OwnerParkingSpots")
  parkingBookings ParkingBooking[] @relation("UserParkingBookings")

  vehicle       Vehicle?
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   // rideId:userId or similar
  text      String
  status    String   @default("SENT") // SENT, DELIVERED, READ
  createdAt DateTime @default(now())

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  @@index([chatId])
}

// ==========================================
// Parking Reservation System Models
// ==========================================

enum ParkingSlotType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum BookingStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

model ParkingSpot {
  id             String                @id @default(uuid())
  spotName       String                @unique
  level          Int                   // 1 to 5
  section        String                // "LEFT", "MIDDLE", "RIGHT"
  row            Int                   // 1 to 3
  col            Int                   // 1 to 4
  ownerId        String?
  owner          User?                 @relation("OwnerParkingSpots", fields: [ownerId], references: [id], onDelete: SetNull)
  approved       Boolean               @default(false)
  priceHourly    Float                 @default(50)
  priceDaily     Float                 @default(100)
  priceWeekly     Float                 @default(500)
  priceMonthly   Float                 @default(1000)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  availabilities ParkingAvailability[]
  bookings       ParkingBooking[]
}

model ParkingAvailability {
  id             String          @id @default(uuid())
  spotId         String
  spot           ParkingSpot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  date           String          // e.g. "2026-05-22"
  slotType       ParkingSlotType @default(HOURLY)
  startTime      DateTime
  endTime        DateTime
  price          Float
  isBooked       Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  bookings       ParkingBooking[]
}

model ParkingBooking {
  id             String              @id @default(uuid())
  spotId         String
  spot           ParkingSpot         @relation(fields: [spotId], references: [id], onDelete: Cascade)
  availabilityId String?
  availability   ParkingAvailability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
  userId         String
  user           User                @relation("UserParkingBookings", fields: [userId], references: [id], onDelete: Cascade)
  date           String              // "2026-05-22"
  slotType       ParkingSlotType
  startTime      DateTime
  endTime        DateTime
  price          Float
  status         BookingStatus       @default(REQUESTED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Vehicle {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleNumber String
  type          String   // "CAR" | "BIKE"
  capacity      Int      // 2 | 5 | 7
  fuelType      String   // "CNG" | "Petrol" | "Diesel"
}

model VerificationCode {
  id          String   @id @default(uuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
}

model PendingNotification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  payload   String   // JSON stringified payload
  createdAt DateTime @default(now())

  @@index([userId])
}

model BuddyRequest {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  riderId        String
  rider          User     @relation("RiderBuddyRequests", fields: [riderId], references: [id], onDelete: Cascade)

  startPlaceName String
  endPlaceName   String
  startTime      DateTime

  startPoint     Unsupported("geometry(Point,4326)")?
  endPoint       Unsupported("geometry(Point,4326)")?

  seatsNeeded    Int      @default(1)
  status         String   @default("OPEN") // "OPEN" | "ACCEPTED" | "CANCELLED"
}
